# Jobclaw Configuration Defaults
# Copy this file to .env and fill in real values for local development.
# Real secrets must NEVER be committed to source control.

# Google Gemini API key (server-side, backend)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Express server port
PORT=3000

# API key required for x-jobclaw-key header in production (NODE_ENV=production).
# In dev, auth is bypassed. Use a strong random value for production deployments.
JOBCLAW_API_KEY=change-me-in-production

# Continuous autopilot cycle interval in milliseconds (default 60000 = 60s)
AUTOPILOT_INTERVAL=60000

# Vite dev HMR control (set to 'true' to disable HMR; useful when running AI agents)
# DISABLE_HMR=true
