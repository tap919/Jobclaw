# Jobclaw Configuration Defaults
# Copy this file to .env and fill in real values for local development.
# Real secrets must NEVER be committed to source control.

# Google Gemini API key (server-side, backend)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Express server port
PORT=3000

# Continuous autopilot cycle interval in milliseconds (default 60000 = 60s)
AUTOPILOT_INTERVAL=60000

# Vite dev HMR control (set to 'true' to disable HMR; useful when running AI agents)
# DISABLE_HMR=true

# Adzuna real job source (https://developer.adzuna.com/)
# Free tier: 250 API calls/month. Used by job_ingest_cron to fetch real jobs.
# Without these, the ingest cron will log a warning and skip the cycle.
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=us
